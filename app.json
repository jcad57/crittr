{
  "expo": {
    "name": "Crittr",
    "slug": "crittr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-temp.png",
    "scheme": "crittr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "statusBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#FDF8F3"
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/app-icon-temp.png",
        "backgroundImage": "./assets/images/app-icon-temp.png",
        "monochromeImage": "./assets/images/app-icon-temp.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.jcadeichmann.crittr"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon-temp.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Crittr to access your photos to set profile and pet avatars, and to add medical document photos.",
          "cameraPermission": "Allow Crittr to use your camera to photograph medical documents and pet avatars."
        }
      ],
      "@react-native-community/datetimepicker",
      "@stripe/stripe-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49a5ae52-3be6-4ecf-a601-a80cc2c5718e"
      }
    },
    "owner": "pegasys-studios"
  }
}
