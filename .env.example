# Copy to `.env` for local development. Never commit real secrets.
# For EAS / TestFlight / App Store builds: set the same `EXPO_PUBLIC_*` variables
# in Expo (Project → Environment variables) or `eas env:push` so they exist at
# compile time — embedded `process.env.EXPO_PUBLIC_*` is baked into the binary.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat public SDK keys (iOS key usually starts with appl_)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
